{
  "name": "photovault-theme",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./assets/css/tailwind.css -o ./css/tailwind.css --minify",
    "test:a11y": "node tests/browser-accessibility.js",
